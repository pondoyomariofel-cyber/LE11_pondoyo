# Initialize empty shopping cart (dictionary to store item: [price, quantity])
shopping_cart = {}

def display_cart():
    """Show all items in cart with details and total"""
    if not shopping_cart:
        print("\nYour shopping cart is empty!")
        return
    
    print("\n--- Your Shopping Cart ---")
    total = 0
    for item, (price, quantity) in shopping_cart.items():
        item_total = price * quantity
        total += item_total
        print(f"{item} - ₱{price:.2f} each - Qty: {quantity} - Subtotal: ₱{item_total:.2f}")
    print(f"\nTotal Cost: ₱{total:.2f}")

def add_item():
    """Add new or existing item to cart"""
    item = input("\nEnter item name: ").strip().title()
    price = float(input(f"Enter price for {item}: ₱"))
    quantity = int(input(f"Enter quantity for {item}: "))
    
    if item in shopping_cart:
        shopping_cart[item][1] += quantity
        print(f"Updated {item} quantity to {shopping_cart[item][1]}!")
    else:
        shopping_cart[item] = [price, quantity]
        print(f"Added {quantity} {item}(s) to cart!")

def remove_item():
    """Remove item from cart or reduce quantity"""
    if not shopping_cart:
        print("\nCart is empty - nothing to remove!")
        return
    
    item = input("\nEnter item name to remove: ").strip().title()
    if item not in shopping_cart:
        print(f"{item} not found in cart!")
        return
    
    choice = input(f"Do you want to remove all {item}(s) or reduce quantity? (all/quantity): ").lower()
    if choice == "all":
        del shopping_cart[item]
        print(f"Removed all {item}(s) from cart!")
    elif choice == "quantity":
        reduce_qty = int(input(f"Enter number of {item}(s) to remove: "))
        if reduce_qty >= shopping_cart[item][1]:
            del shopping_cart[item]
            print(f"Removed all {item}(s) (quantity exceeded current stock)!")
        else:
            shopping_cart[item][1] -= reduce_qty
            print(f"Updated {item} quantity to {shopping_cart[item][1]}!")
    else:
        print("Invalid choice - no changes made!")

# Main program loop
print("=== Python Shopping Cart ===")
while True:
    print("\nMenu Options:")
    print("1. Add Item to Cart")
    print("2. View Shopping Cart")
    print("3. Remove Item from Cart")
    print("4. Exit")
    
    choice = input("\nEnter your choice (1-4): ")
    if choice == "1":
        add_item()
    elif choice == "2":
        display_cart()
    elif choice == "3":
        remove_item()
    elif choice == "4":
        print("\nThank you for shopping! Goodbye!")
        break
    else:
        print("Invalid choice - please enter a number between 1 and 4!")